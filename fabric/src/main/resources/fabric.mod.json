{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "license": "${license}",
    "icon": "assets/${mod_id}/icon.png",
    "environment": "*",
    "entrypoints": {
        "stator:main": [
            "com.example.examplemod.ExampleMod"
        ],
        "stator:client": [
            "com.example.examplemod.client.ExampleModClient"
        ]
    },
    "mixins": [
        "${mod_id}.mixins.json",
        "${mod_id}.client.mixins.json"
    ],
    "depends": {
        "minecraft": "~${minecraft_version}",
        "java": ">=${java_version}",
        "dynamo": ">=${fabric_dynamo_version}"
    }
}
  